# Wolai API Token (required)
WOLAI_TOKEN=sk-your-token-here

# Embedding model (optional, defaults to qwen3-embedding:0.6b)
# Options:
#   qwen3-embedding:0.6b  — 1024-dim, bilingual CN/EN, 32K context, ~2.6GB RAM (recommended)
#   nomic-embed-text       —  768-dim, English-focused, smaller, ~500MB RAM (lightweight)
#   bge-m3                 — 1024-dim, multilingual, ~2GB RAM (good multilingual alternative)
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# Optional: entry page ID for page discovery (children scanned for sub-pages)
# WOLAI_DASHBOARD_ID=your-page-id-here
